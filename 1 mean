# Using libraries for statistical calculations

import statistics
import numpy as np

# Input
data = list(map(float, input("Enter numbers separated by space: ").split()))

# Calculations
mean_value = statistics.mean(data)
median_value = statistics.median(data)

# Mode (handle multiple modes safely)
try:
    mode_value = statistics.mode(data)
except statistics.StatisticsError:
    mode_value = statistics.multimode(data)

variance_value = np.var(data)          # Population variance
std_deviation = np.std(data)           # Population standard deviation

# Output
print("\nResults:")
print("Mean =", mean_value)
print("Median =", median_value)
print("Mode =", mode_value)
print("Variance =", variance_value)
print("Standard Deviation =", std_deviation)
print("Mean =", mean(data))
print("Median =", median(data))
print("Mode =", mode(data))
print("Variance =", variance(data))
print("Standard Deviation =", standard_deviation(data))
